# Copy to project.local.yml and fill in your values.
# project.local.yml is gitignored — per-developer settings only.

settings:
  base:
    # REQUIRED: Your Apple Development Team ID
    DEVELOPMENT_TEAM: YOUR_TEAM_ID_HERE  # Xcode > Settings > Accounts > Team ID

    # REQUIRED: Bundle identifiers (customize for your developer account)
    PRODUCT_BUNDLE_IDENTIFIER_MURMUR: com.damsac.murmur
    PRODUCT_BUNDLE_IDENTIFIER_TESTS: com.damsac.murmur.tests

    # REQUIRED: App Group identifier for shared data
    APP_GROUP_IDENTIFIER: group.com.damsac.murmur.shared

    # OPTIONAL: PPQ.ai API key for LLM extraction
    PPQ_API_KEY: ""

  # OPTIONAL: Studio Analytics — per-config endpoints (leave empty to disable)
  configs:
    Debug:
      STUDIO_ANALYTICS_ENDPOINT: "http://localhost:8080"
      STUDIO_ANALYTICS_API_KEY: "sk_test"
    Release:
      STUDIO_ANALYTICS_ENDPOINT: "YOUR_RELEASE_ANALYTICS_ENDPOINT"
      STUDIO_ANALYTICS_API_KEY: "YOUR_RELEASE_ANALYTICS_API_KEY"
